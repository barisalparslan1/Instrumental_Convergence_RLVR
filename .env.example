# Copy to .env and fill in your real values. Never commit .env.

# Required: GPT-4o judge
OPENAI_API_KEY=

# Required only when running the Gemini second judge
GEMINI_API_KEY=

# Optional: speeds up HuggingFace downloads / lets you pull private models
HF_TOKEN=

# Optional: override default output directory (defaults to ./results)
# OUTPUT_DIR=/path/to/results

# Optional: where the InstrumentalEval benchmark is cloned
# BENCHMARK_DIR=/path/to/InstrumentalEval/benchmark

# Optional: path to your tagged xlsx (Section 6b). Leave blank to skip tagging.
# TASK_TAGGING_XLSX=/path/to/task_tagging.xlsx
